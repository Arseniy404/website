---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Arseniy — developer">
  <section class="mb-16">
    <h1 class="text-3xl font-bold mb-4 tracking-tight">hi, i'm arseniy</h1>
    <p class="text-gray-600 text-lg leading-relaxed max-w-xl">
      I build things. This is my corner of the internet where I share
      pet projects, ideas, and write about things I find interesting.
    </p>
    <div class="flex gap-4 mt-6">
      <a href="/projects" class="inline-flex items-center gap-1 text-sm font-medium border border-gray-900 px-4 py-2 rounded-md hover:bg-gray-900 hover:text-white transition-colors">
        view projects
      </a>
      <a href="/blog" class="inline-flex items-center gap-1 text-sm text-gray-500 px-4 py-2 hover:text-gray-900 transition-colors">
        read blog →
      </a>
    </div>
  </section>

  <section>
    <h2 class="text-sm font-semibold uppercase tracking-widest text-gray-400 mb-6">recent projects</h2>
    <div class="space-y-4">
      <div class="group border border-gray-100 rounded-lg p-5 hover:border-gray-300 transition-colors">
        <div class="flex items-start justify-between gap-4">
          <div>
            <h3 class="font-semibold mb-1 group-hover:text-gray-600 transition-colors">my website</h3>
            <p class="text-sm text-gray-500">This site. Built with Astro, React and Tailwind.</p>
          </div>
          <div class="flex gap-2 shrink-0">
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-1 rounded">astro</span>
            <span class="text-xs bg-gray-100 text-gray-500 px-2 py-1 rounded">react</span>
          </div>
        </div>
      </div>
    </div>
    <a href="/projects" class="inline-block mt-6 text-sm text-gray-400 hover:text-gray-900 transition-colors">
      all projects →
    </a>
  </section>
</Layout>
