---
import Layout from '../layouts/Layout.astro';

const projects = [
  {
    title: 'my website',
    description: 'Personal site to share projects, blog posts and demos.',
    tags: ['astro', 'react', 'tailwind'],
    github: 'https://github.com/arseniyyastrebov/my-website',
    demo: '/',
  },
];
---

<Layout title="Projects — Arseniy">
  <h1 class="text-3xl font-bold mb-2 tracking-tight">projects</h1>
  <p class="text-gray-500 mb-10">things i've built or am building</p>

  <div class="space-y-4">
    {projects.map((p) => (
      <div class="border border-gray-100 rounded-lg p-6 hover:border-gray-300 transition-colors">
        <div class="flex items-start justify-between gap-4 flex-wrap">
          <div class="flex-1 min-w-0">
            <h2 class="font-semibold text-lg mb-1">{p.title}</h2>
            <p class="text-sm text-gray-500 mb-3">{p.description}</p>
            <div class="flex gap-2 flex-wrap">
              {p.tags.map((t) => (
                <span class="text-xs bg-gray-100 text-gray-500 px-2 py-1 rounded">{t}</span>
              ))}
            </div>
          </div>
          <div class="flex gap-3 shrink-0">
            {p.github && (
              <a href={p.github} target="_blank" rel="noopener" class="text-xs text-gray-400 hover:text-gray-900 transition-colors font-medium">
                github ↗
              </a>
            )}
            {p.demo && (
              <a href={p.demo} class="text-xs text-gray-400 hover:text-gray-900 transition-colors font-medium">
                demo ↗
              </a>
            )}
          </div>
        </div>
      </div>
    ))}
  </div>
</Layout>
