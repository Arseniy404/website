---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = 'Personal website — projects, blog, experiments' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <meta name="description" content={description} />
    <title>{title}</title>
  </head>
  <body class="bg-white text-gray-900 min-h-screen flex flex-col antialiased">
    <header class="border-b border-gray-100">
      <nav class="max-w-3xl mx-auto px-6 py-4 flex items-center justify-between">
        <a href="/" class="font-semibold text-lg tracking-tight hover:text-gray-600 transition-colors">
          arseniy
        </a>
        <ul class="flex gap-6 text-sm text-gray-500">
          <li><a href="/projects" class="hover:text-gray-900 transition-colors">projects</a></li>
          <li><a href="/blog" class="hover:text-gray-900 transition-colors">blog</a></li>
        </ul>
      </nav>
    </header>

    <main class="flex-1 max-w-3xl mx-auto w-full px-6 py-12">
      <slot />
    </main>

    <footer class="border-t border-gray-100">
      <div class="max-w-3xl mx-auto px-6 py-6 flex items-center justify-between text-sm text-gray-400">
        <span>arseniy</span>
        <div class="flex gap-4">
          <a href="https://github.com/arseniyyastrebov" target="_blank" rel="noopener" class="hover:text-gray-700 transition-colors">github</a>
        </div>
      </div>
    </footer>
  </body>
</html>
